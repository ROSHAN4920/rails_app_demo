apiVersion: v1
kind: Service
metadata:
  name: rails-app
  namespace: rails-app
spec:
  selector:
    app: rails
  ports:
    - protocol: TCP
      port: 3000
      targetPort: 3000
  type: ClusterIP

---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: rails-app
  namespace: rails-app
spec:
  replicas: 1
  selector:
    matchLabels:
      app: rails
  template:
    metadata:
      labels:
        app: rails
    spec:
      containers:
        - name: rails
          image: 
          ports:
            - containerPort: 3000
          env:
            - name: SECRET_KEY_BASE
              valueFrom:
                secretKeyRef:
                  name: rails-secret
                  key: SECRET_KEY_BASE
            - name: DATABASE_PASSWORD
              valueFrom:
                secretKeyRef:
                  name: rails-secret
                  key: DATABASE_PASSWORD
            - name: DATABASE_HOST
              value: postgres.rails-app.svc.cluster.local
            - name: DATABASE_USERNAME
              value: postgres
            - name: RAILS_ENV
              value: production
